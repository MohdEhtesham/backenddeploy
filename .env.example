# Copy this to .env and fill real values

# Server
NODE_ENV=development
PORT=4000

# MongoDB (use MongoDB Atlas free tier)
# Get a free cluster at https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/aabroo?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=30d

# CORS — comma separated origins. Use * for everything (dev only)
CORS_ORIGINS=*

# Cloudinary (https://console.cloudinary.com/)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: rate limit (requests per 15 min per IP)
RATE_LIMIT_MAX=300
